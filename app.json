{
  "name": "minister-x",
  "version": "5.0.0",
  "description": "MinisterX-md Whatsapp bot built to enhance Whatsapp features by KIJANA YA MINISTER",
  "logo": "https://tse3.mm.bing.net/th/id/OIP.0yDRGCrSjMs-n8QC9RZhQgHaD1?r=0&rs=1&pid=ImgDetMain&o=7&rm=3",
  "keywords": ["minister", "minister-baileys", "minister-btns", "minister-api"],
  "success_url": "/",
  "stack": "heroku-24",
  "env": {
    "SESSION_ID": {
      "description": "Minister~",
      "required": true,
      "value": ""
    },
    "MODE": {
      "description": "Worktype of your bot. Use 'public' (everyone can use it) or 'private' (only bot number).",
      "required": true,
      "value": "private"
    },
    "TIME_ZONE": {
      "description": "Your timezone e.g. Africa/Nairobi, America/New_York, Asia/Kolkata",
      "required": true,
      "value": "Africa"
    },
    "AUTO_LIKE_STATUS": {
      "description": "Auto-like WhatsApp statuses. Set true or false.",
      "required": false,
      "value": "false"
    },
    "AUTO_READ_STATUS": {
      "description": "Auto-view WhatsApp statuses. Set true or false.",
      "required": false,
      "value": "false"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL connection URL. Leave blank to use the auto-provisioned Heroku Postgres addon, or supply your own (Neon, Supabase, etc.). Falls back to SQLite if empty and no addon is attached.",
      "required": false,
      "value": ""
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0",
      "as": "DATABASE"
    }
  ],
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "environments": {
    "test": {
      "addons": [],
      "env": {
        "DATABASE_URL": ""
      }
    }
  }
}
